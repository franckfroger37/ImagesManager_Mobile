{
  "expo": {
    "name": "Images Manager V2",
    "slug": "images-manager",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2563eb"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "experiments": {
      "baseUrl": "/ImagesManager_Mobile"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.lemondedechristine.imagesmanager"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#2563eb"
      },
      "package": "com.lemondedechristine.imagesmanager",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "INTERNET"
      ]
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Autorisez Images Manager a acceder a vos photos.",
          "cameraPermission": "Autorisez Images Manager a utiliser l'appareil photo."
        }
      ]
    ]
  }
}